APP_NAME=newArytmie
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://newarytmie.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=newarytmie
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# Pro nahledy ve storage/app/public (galerie) pouzij public
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Cloudflare Turnstile (kontaktní formulář na úvodní stránce)
# https://dash.cloudflare.com/ → Turnstile → vytvořit widget → zkopírovat klíče
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Členská sekce (/pro-cleny) — jedno sdílené heslo, bez uživatelských účtů
MEMBERS_AREA_ENABLED=true
MEMBERS_AREA_PASSWORD=

# Členský kalendář (Harmonogram) — embed + iCal pro telefony
MEMBERS_GOOGLE_CALENDAR_EMBED_SRC=p31orcdhs63gctav51ufi0ohmo@group.calendar.google.com
MEMBERS_GOOGLE_CALENDAR_ICAL_URL=https://calendar.google.com/calendar/ical/p31orcdhs63gctav51ufi0ohmo%40group.calendar.google.com/public/basic.ics
MEMBERS_GOOGLE_CALENDAR_TIMEZONE=Europe/Prague
MEMBERS_GOOGLE_CALENDAR_MODE=AGENDA

# Google Calendar — embed na úvodu (sekce Koncerty). ID kalendáře z Google Kalendář → nastavení kalendáře → Integrace.
# Příklad z adresy cid=… : odkaz vede na …57237aea…8b@group.calendar.google.com
GOOGLE_CALENDAR_EMBED_SRC=
GOOGLE_CALENDAR_TIMEZONE=Europe/Prague
# AGENDA = seznam termínů, MONTH = měsíční mřížka
GOOGLE_CALENDAR_MODE=AGENDA
